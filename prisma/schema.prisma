generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email               String               @unique
  passwordHash        String               @map("password_hash")
  displayName         String?              @map("display_name")
  role                Role                 @default(USER)
  isHidden            Boolean              @default(false) @map("is_hidden")
  createdAt           DateTime             @default(now()) @map("created_at")
  submissions         CafeSubmission[]
  passwordResetTokens PasswordResetToken[]
  savedCafes          SavedCafe[]
  savedCollections    SavedCollection[]
  cafeVotes           CafeVote[]

  @@map("users")
}

model PasswordResetToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  token     String   @unique
  userId    String   @map("user_id") @db.Uuid
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model Cafe {
  id                String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String
  nameEn            String?                   @map("name_en")
  slug              String                    @unique
  address           String?
  addressEn         String?                   @map("address_en")
  district          String?
  districtEn        String?                   @map("district_en")
  district_legacy   String?
  location          Unsupported("geography")?
  googlePlaceId     String?                   @map("google_place_id")
  googleMapsUrl     String?                   @map("google_maps_url")
  openingTime       DateTime?                 @map("opening_time") @db.Time(6)
  closingTime       DateTime?                 @map("closing_time") @db.Time(6)
  priceMin          Int?                      @map("price_min")
  priceMax          Int?                      @map("price_max")
  oneLiner          String?                   @map("one_liner")
  oneLinerEn        String?                   @map("one_liner_en")
  description       String?
  descriptionEn     String?                   @map("description_en")
  signatureDrink    String?                   @map("signature_drink")
  signatureDrinkEn  String?                   @map("signature_drink_en")
  rating            Decimal?                  @db.Decimal(3, 2)
  vibes             String[]
  vibesEn           String[]                  @default([]) @map("vibes_en")
  purposes          String[]
  purposesEn        String[]                  @default([]) @map("purposes_en")
  amenities         String[]
  amenitiesEn       String[]                  @default([]) @map("amenities_en")
  tags              String[]                  @default([])
  tagsEn            String[]                  @default([]) @map("tags_en")
  parkingLocation   String?                   @map("parking_location")
  parkingLocationEn String?                   @map("parking_location_en")
  images            String[]
  imageOrientations String[]                  @default([]) @map("image_orientations")
  coverImage        String?                   @map("cover_image")
  menuImage         String?                   @map("menu_image")
  instagramUrl      String?                   @map("instagram_url")
  isFeatured        Boolean?                  @default(false) @map("is_featured")
  featuredOrder     Int?                      @map("featured_order")
  search_vector     Unsupported("tsvector")?
  isPublished       Boolean                   @default(true) @map("is_published")
  createdAt         DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime                  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  savedCafes        SavedCafe[]
  cafeVotes         CafeVote[]

  @@index([amenities], map: "idx_cafes_amenities", type: Gin)
  @@index([tags], map: "idx_cafes_tags", type: Gin)
  @@index([tagsEn], map: "idx_cafes_tags_en", type: Gin)
  @@index([district], map: "idx_cafes_district")
  @@index([districtEn], map: "idx_cafes_district_en")
  @@index([district_legacy], map: "idx_cafes_district_leg")
  @@index([isFeatured, featuredOrder], map: "idx_cafes_featured")
  @@index([openingTime, closingTime], map: "idx_cafes_hours")
  @@index([location], map: "idx_cafes_location", type: Gist)
  @@index([priceMin, priceMax], map: "idx_cafes_price")
  @@index([isPublished], map: "idx_cafes_published")
  @@index([purposes], map: "idx_cafes_purposes", type: Gin)
  @@index([search_vector], map: "idx_cafes_search", type: Gin)
  @@index([vibes], map: "idx_cafes_vibes", type: Gin)
  @@map("cafes")
}

model SavedCafe {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  cafeId         String   @map("cafe_id") @db.Uuid
  collectionName String?  @map("collection_name")
  createdAt      DateTime @default(now()) @map("created_at")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cafe           Cafe     @relation(fields: [cafeId], references: [id], onDelete: Cascade)

  @@unique([userId, cafeId])
  @@index([cafeId], map: "idx_saved_cafes_cafe_id")
  @@map("saved_cafes")
}

model SavedCollection {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@map("saved_collections")
}

model CafeVote {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  cafeId    String   @map("cafe_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cafe      Cafe     @relation(fields: [cafeId], references: [id], onDelete: Cascade)

  @@unique([userId, cafeId])
  @@index([cafeId], map: "idx_cafe_votes_cafe_id")
  @@index([createdAt], map: "idx_cafe_votes_created_at")
  @@index([cafeId, createdAt], map: "idx_cafe_votes_cafe_created_at")
  @@map("cafe_votes")
}

model CafeSubmission {
  id            String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  submittedById String?          @map("submitted_by") @db.Uuid
  name          String
  address       String?
  googleMapsUrl String?          @map("google_maps_url")
  note          String?
  reviewNote    String?          @map("review_note")
  status        SubmissionStatus @default(pending)
  createdAt     DateTime         @default(now()) @map("created_at")
  submittedBy   User?            @relation(fields: [submittedById], references: [id])

  @@map("cafe_submissions")
}

model BlogPost {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug           String    @unique
  heroImage      String?   @map("hero_image")
  accent         String    @default("amber")
  tags           String[]  @default([])
  titleVi        String    @map("title_vi")
  titleEn        String?   @map("title_en")
  excerptVi      String    @map("excerpt_vi")
  excerptEn      String?   @map("excerpt_en")
  categoryVi     String    @map("category_vi")
  categoryEn     String?   @map("category_en")
  readTimeVi     String?   @map("read_time_vi")
  readTimeEn     String?   @map("read_time_en")
  author         String    @default("Cafe Maps Editorial")
  moodVi         String?   @map("mood_vi")
  moodEn         String?   @map("mood_en")
  locationVi     String?   @map("location_vi")
  locationEn     String?   @map("location_en")
  heroImageAltVi String?   @map("hero_image_alt_vi")
  heroImageAltEn String?   @map("hero_image_alt_en")
  introVi        String?   @map("intro_vi")
  introEn        String?   @map("intro_en")
  pullQuoteVi    String?   @map("pull_quote_vi")
  pullQuoteEn    String?   @map("pull_quote_en")
  sectionsVi     Json      @default("[]") @map("sections_vi")
  sectionsEn     Json      @default("[]") @map("sections_en")
  checklistVi    String[]  @default([]) @map("checklist_vi")
  checklistEn    String[]  @default([]) @map("checklist_en")
  isFeatured     Boolean   @default(false) @map("is_featured")
  featuredOrder  Int?      @map("featured_order")
  isPublished    Boolean   @default(false) @map("is_published")
  publishedAt    DateTime? @map("published_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([isPublished, publishedAt], map: "idx_blog_posts_published")
  @@index([isFeatured, featuredOrder], map: "idx_blog_posts_featured")
  @@index([tags], map: "idx_blog_posts_tags", type: Gin)
  @@map("blog_posts")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model spatial_ref_sys {
  srid      Int     @id
  auth_name String? @db.VarChar(256)
  auth_srid Int?
  srtext    String? @db.VarChar(2048)
  proj4text String? @db.VarChar(2048)
}

enum Role {
  USER
  ADMIN
}

enum SubmissionStatus {
  pending
  approved
  rejected
}

enum PriceRange {
  under_50k
  k_100k     @map("50k_100k")
  k_150k     @map("100k_150k")
  above_150k
}
