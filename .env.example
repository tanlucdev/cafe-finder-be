# Database
# Dùng Session Pooler URL cho local (IPv4) — lấy từ Supabase > Project Settings > Database > Connection Pooling > Session mode
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"
# DIRECT_URL — local: Session Pooler; trên Render/server IPv6: dùng direct URL
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# JWT
JWT_SECRET="generate-a-strong-random-secret-here"
JWT_EXPIRES_IN="7d"

# Supabase Storage (chỉ dùng cho ảnh)
SUPABASE_URL="https://xxx.supabase.co"
SUPABASE_SERVICE_KEY="your-service-role-key"
SUPABASE_BUCKET="cafe-images"

# Google Places API (optional)
GOOGLE_PLACES_API_KEY="your-google-api-key"

# App
PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"
APP_URL="http://localhost:3000"

# Resend Email — đăng ký tại resend.com, free 3000 email/tháng
RESEND_API_KEY="re_xxxxxxxxxxxx"
# Email gửi đi — cần verify domain trên Resend (production); dev dùng onboarding@resend.dev
RESEND_FROM_EMAIL="noreply@yourdomain.com"
